# DataJud / CNJ
# Solicitar em: https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=

# Código numérico da vara no orgaoJulgador.codigo (tem precedência sobre VARA_NOME)
# Ex: 1234567  (verificar no DataJud consultando orgaoJulgador da vara)
VARA_CODIGO=

# Nome exato da vara como aparece no DataJud (usado quando VARA_CODIGO não está definido)
# Ex: 17ª VARA DO TRABALHO DE BELO HORIZONTE
VARA_NOME=

# Senha de acesso ao dashboard /pje-dashboard (padrão: pje)
DASHBOARD_PASSWORD=pje

# Railway injeta automaticamente
PORT=3000
